---
import '../styles/globals.css';

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  preloadImage?: string;
}

const {
  title = 'Moose — One subscription. Every studio.',
  description = 'Moose is the crossover access pass for boutique fitness studios. Fill empty slots, keep your members loyal, get paid weekly. 218 partner studios across Australia.',
  canonical,
  ogImage = '/og.png',
  preloadImage,
} = Astro.props;

const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? '';
const canonicalUrl = canonical ?? `${siteUrl}${Astro.url.pathname}`;
const ogImageUrl = ogImage.startsWith('http') ? ogImage : `${siteUrl}${ogImage}`;

const orgJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Moose',
  url: siteUrl || 'https://trainmoose.com',
  logo: `${siteUrl}/brand/logo/moose-wordmark-twotone.svg`,
  description,
  areaServed: {
    '@type': 'Country',
    name: 'Australia',
  },
  email: 'partnerships@trainmoose.com',
  sameAs: ['https://www.instagram.com/trainmoose/'],
};

const serviceJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Moose crossover access',
  serviceType: 'Reciprocal fitness studio partnership network',
  provider: { '@type': 'Organization', name: 'Moose', url: siteUrl || 'https://trainmoose.com' },
  areaServed: { '@type': 'Country', name: 'Australia' },
  description:
    'A premium membership upgrade ($11/wk) sold by partner boutique fitness studios that entitles members to 4 sessions per month at complementary, non-competing partner venues nearby.',
  offers: {
    '@type': 'Offer',
    price: '11',
    priceCurrency: 'AUD',
    priceSpecification: {
      '@type': 'UnitPriceSpecification',
      price: '11',
      priceCurrency: 'AUD',
      unitText: 'WEEK',
    },
    eligibleQuantity: {
      '@type': 'QuantitativeValue',
      value: '4',
      unitText: 'sessions per month',
    },
  },
  audience: { '@type': 'BusinessAudience', audienceType: 'Boutique fitness studio operators' },
};
---

<!doctype html>
<html lang="en-AU">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800&display=swap"
    />

    <link rel="icon" type="image/svg+xml" href="/brand/logo/moose-icon-pink.svg" />
    <link rel="icon" type="image/png" sizes="40x40" href="/brand/icon/Icon-40.png" />
    <link rel="icon" type="image/png" sizes="180x180" href="/brand/icon/Icon-60@3x.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/brand/icon/Icon-60@3x.png" />
    <meta name="theme-color" content="#1A2B5F" />

    {preloadImage && (
      <link rel="preload" as="image" href={preloadImage} fetchpriority="high" />
    )}

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name" content="Moose" />
    <meta property="og:locale" content="en_AU" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <script type="application/ld+json" set:html={JSON.stringify(orgJsonLd)} />
    <script type="application/ld+json" set:html={JSON.stringify(serviceJsonLd)} />

    <!-- Gate for the scroll-reveal styles: without JS the page renders
         fully visible. Inline so it lands before first paint. -->
    <script is:inline>document.documentElement.classList.add('js');</script>
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to content</a>
    <slot />

    <script>
      // Scroll reveal — adds .is-revealed once an element enters the viewport.
      // Styles live in globals.css under the html.js gate.
      const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      const revealEls = document.querySelectorAll<HTMLElement>('[data-reveal]');
      const revealIO = new IntersectionObserver(
        (entries, io) => {
          for (const entry of entries) {
            if (!entry.isIntersecting) continue;
            entry.target.classList.add('is-revealed');
            io.unobserve(entry.target);
          }
        },
        { threshold: 0.12, rootMargin: '0px 0px -6% 0px' }
      );
      revealEls.forEach((el) => revealIO.observe(el));

      // Count-up — elements with data-countup tick from 0 to their rendered
      // value on first view. Non-numeric prefix/suffix ("$", "k", "+") are
      // preserved, so copy stays the single source of truth.
      const countEls = document.querySelectorAll<HTMLElement>('[data-countup]');
      const countIO = new IntersectionObserver(
        (entries, io) => {
          for (const entry of entries) {
            if (!entry.isIntersecting) continue;
            io.unobserve(entry.target);
            runCount(entry.target as HTMLElement);
          }
        },
        { threshold: 0.6 }
      );

      function runCount(el: HTMLElement) {
        const text = (el.textContent ?? '').trim();
        const match = text.match(/^([^\d]*)(\d+(?:\.\d+)?)(.*)$/);
        if (!match || reduceMotion) return;
        const [, pre, numStr, post] = match;
        const target = parseFloat(numStr);
        const decimals = (numStr.split('.')[1] ?? '').length;
        const duration = 1100;
        const start = performance.now();
        const tick = (now: number) => {
          const k = Math.min(1, (now - start) / duration);
          const eased = 1 - Math.pow(1 - k, 3);
          el.textContent = pre + (target * eased).toFixed(decimals) + post;
          if (k < 1) requestAnimationFrame(tick);
        };
        requestAnimationFrame(tick);
      }
      countEls.forEach((el) => countIO.observe(el));
    </script>
  </body>
</html>
