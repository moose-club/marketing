---
import { VALUE } from '../../data/copy';
---

<section class="section section--white" id="value" aria-labelledby="valueHeading">
  <div class="container">
    <div class="value__head">
      <span class="eyebrow" data-reveal>{VALUE.eyebrow}</span>
      <h2 id="valueHeading" class="value__prize" data-reveal style="--ri:1" set:html={VALUE.headHtml}></h2>
      <p class="value__note" data-reveal style="--ri:2">{VALUE.prizeNote}</p>
    </div>

    <div class="value__table">
      <div class="value__cards value__cards--benefits">
        {VALUE.benefits.map((b, i) => (
          <div class="value__bcard" data-reveal="pop" style={`--ri:${1 + i}`}>
            <span class="value__num">{b.n}</span>
            <h4>{b.title}</h4>
            <p>{b.body}</p>
            <div class="value__statbox">
              <div class="value__stat">
                <span class="tnum" data-countup>{b.stat}</span>
                {b.unit && <span class="value__unit">{b.unit}</span>}
              </div>
              <p class="value__cap">{b.cap}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  /* White background distinguishes this section from the cream sections that
     bracket it (the cards go cream to keep the surface separation). */
  .section--white { background: #fff; }

  .value__head { max-width: 780px; margin-bottom: 48px; }
  .value__prize {
    font-size: clamp(24px, 3.4vw, 46px);
    font-weight: 700;
    line-height: 1.18;
    letter-spacing: -0.02em;
    color: var(--navy);
  }
  .value__prize em {
    color: var(--pink);
    font-style: normal;
  }
  .value__note {
    font-size: 17px;
    color: var(--ink-dim);
    margin-top: 22px;
    max-width: 580px;
    line-height: 1.55;
  }

  .value__table { width: 100%; }

  .value__cards {
    display: grid;
    grid-template-columns: 1fr;
    gap: 22px;
    align-items: stretch;
  }

  /* Navy benefit card with a cream quantification box pinned to the bottom. */
  .value__bcard {
    display: flex;
    flex-direction: column;
    background: var(--navy);
    border-radius: var(--r-sheet);
    padding: 26px 24px;
    box-shadow: var(--shadow-sm);
    transition: transform var(--dur-base) var(--ease-out), box-shadow var(--dur-base) var(--ease-out);
  }
  .value__bcard:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
  }
  .value__num {
    font-weight: 800;
    font-size: clamp(28px, 2.4vw, 34px);
    color: #fff;
    line-height: 1;
  }
  .value__bcard h4 {
    font-size: 17px;
    font-weight: 700;
    color: #fff;
    margin: 20px 0 10px;
    line-height: 1.2;
  }
  .value__bcard > p {
    font-size: 13.5px;
    color: rgba(255, 255, 255, 0.72);
    line-height: 1.55;
    margin: 0;
    /* Guaranteed gap between the body copy and the stat box below it. */
    margin-bottom: 28px;
  }

  /* Cream stat box — bottom-pinned via margin-top:auto. Constrained to the
     card width (min-width:0) so a long stat word can't bulge it out, and given
     a uniform min-height so every box is the same size. With equal-height cards
     + bottom pinning, equal box height means the box tops line up too. */
  .value__statbox {
    margin-top: auto;
    width: 100%;
    min-width: 0;
    background: var(--cream);
    border-radius: var(--r-card);
    padding: 24px 22px 26px;
  }
  .value__stat {
    font-weight: 800;
    font-size: clamp(24px, 2.4vw, 32px);
    color: var(--navy);
    letter-spacing: -0.02em;
    line-height: 1;
    display: flex;
    align-items: flex-end;
    min-width: 0;
  }
  .value__unit {
    font-size: 0.42em;
    color: var(--ink-dim);
    font-weight: 600;
    margin-left: 5px;
    letter-spacing: 0;
  }
  .value__cap {
    font-size: 11.5px;
    color: var(--ink-dim);
    margin-top: 12px;
    line-height: 1.5;
    /* Reserve space for the longest caption so all boxes match height. */
    min-height: 4.5em;
  }

  @media (min-width: 640px) {
    .value__cards { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  }
  @media (min-width: 960px) {
    .value__cards { grid-template-columns: repeat(3, minmax(0, 1fr)); }
  }
  @media (min-width: 1280px) {
    /* Break the 5-card row out wider than the 1240px container so each card
       gets more width. Centred on the page; heading stays at container width. */
    .value__cards--benefits {
      grid-template-columns: repeat(5, minmax(0, 1fr));
      width: min(94vw, 1520px);
      position: relative;
      left: 50%;
      transform: translateX(-50%);
    }
  }
</style>
