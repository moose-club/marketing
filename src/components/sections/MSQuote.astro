---
import Eyebrow from '../primitives/Eyebrow.astro';
import StudioTile from '../primitives/StudioTile.astro';
import { QUOTES, resolvePartner, PARTNERS } from '../../data/copy';

// Resolve each quote's studio for the mini-tile.
const partnerByKey = Object.fromEntries(
  PARTNERS.flatMap((p) => ('k' in p ? [[p.k, resolvePartner(p)]] : []))
);

const [hero, ...rest] = QUOTES;
const heroPartner = partnerByKey[hero.studioKey];
---

<section class="quote">
  <div class="container">
    <Eyebrow>What partners say</Eyebrow>

    <figure class="quote__hero">
      <blockquote class="display-m quote__text">
        &ldquo;{hero.q}&rdquo;
      </blockquote>
      <figcaption class="quote__attr">
        {heroPartner && (
          <StudioTile partner={heroPartner} variant="inline" />
        )}
        <div>
          <div class="quote__name">{hero.name}</div>
          <div class="quote__role">{hero.role}</div>
        </div>
      </figcaption>
    </figure>

    {rest.length > 0 && (
      <div class="quote__rest">
        {rest.map((q) => {
          const p = partnerByKey[q.studioKey];
          return (
            <figure>
              <blockquote class="quote__small-text">&ldquo;{q.q}&rdquo;</blockquote>
              <figcaption class="quote__attr quote__attr--small">
                {p && <StudioTile partner={p} variant="inline" />}
                <div>
                  <div class="quote__name">{q.name}</div>
                  <div class="quote__role">{q.role}</div>
                </div>
              </figcaption>
            </figure>
          );
        })}
      </div>
    )}
  </div>
</section>

<style>
  .quote {
    background: var(--card);
    border-top: 1px solid var(--rule);
    border-bottom: 1px solid var(--rule);
    padding-block: clamp(80px, 12vw, 120px);
  }
  .quote :global(.eyebrow) { margin-bottom: 36px; }

  .quote__hero { margin: 0; }
  .quote__text {
    font-weight: 600;
    color: var(--ink);
    max-width: 1080px;
  }

  .quote__attr {
    margin-top: 40px;
    display: flex;
    align-items: center;
    gap: 14px;
  }
  .quote__attr--small { margin-top: 24px; }
  .quote__name { font-size: 15px; font-weight: 700; color: var(--ink); letter-spacing: -0.2px; }
  .quote__role { font-size: 13px; color: var(--ink-dim); margin-top: 2px; }

  .quote__rest {
    margin-top: clamp(48px, 8vw, 72px);
    display: grid;
    grid-template-columns: 1fr;
    gap: 40px;
    padding-top: 40px;
    border-top: 1px solid var(--rule);
  }
  .quote__small-text {
    font-size: clamp(17px, 1.6vw, 20px);
    font-weight: 500;
    line-height: 1.4;
    color: var(--ink);
  }

  @media (min-width: 760px) {
    .quote__rest { grid-template-columns: 1fr 1fr; gap: 48px; }
  }
</style>
