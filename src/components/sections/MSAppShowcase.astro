---
import Eyebrow from '../primitives/Eyebrow.astro';
import PhoneFrame from '../primitives/PhoneFrame.astro';
import ScreenHome from '../islands/ScreenHome';
import ScreenSchedule from '../islands/ScreenSchedule';
import ScreenCancelFlow from '../islands/ScreenCancelFlow';
import { SHOWCASE } from '../../data/copy';
---

<section class="show" id="showcase">
  <div class="container">
    <Eyebrow>What your members see</Eyebrow>
    <h2 class="display-m show__head">
      Everything they need to discover you,
      <span class="ink-dim"> book you, and stay with you.</span>
    </h2>

    <div class="show__rail">
      {SHOWCASE.map((card) => (
        <article class="show__card">
          <div class="show__copy">
            <div class="show__eyebrow">{card.eyebrow}</div>
            <h3 class="show__title">{card.title}</h3>
            <p class="show__caption">{card.caption}</p>
          </div>
          <div class="show__phone">
            <PhoneFrame>
              {card.screen === 'home'     && <ScreenHome     client:visible />}
              {card.screen === 'schedule' && <ScreenSchedule client:visible />}
              {card.screen === 'cancel'   && <ScreenCancelFlow client:visible />}
            </PhoneFrame>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .show {
    background: var(--card);
    border-top: 1px solid var(--rule);
    border-bottom: 1px solid var(--rule);
    padding-block: clamp(80px, 12vw, 120px);
  }
  .show :global(.eyebrow) { margin-bottom: 28px; }
  .show__head {
    margin: 28px 0 56px;
    max-width: 900px;
  }
  .show__head .ink-dim { color: var(--ink-dim); }

  .show__rail {
    display: grid;
    grid-template-columns: 1fr;
    gap: 48px;
  }
  .show__card {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: left;
    background: #F7F5F0;
    border: 1px solid var(--rule);
    border-radius: var(--r-card);
    padding: 40px 28px 0;
    overflow: hidden;
  }
  .show__copy { width: 100%; max-width: 360px; }
  .show__eyebrow {
    font-size: 11px;
    font-weight: 700;
    color: var(--ink-dim);
    letter-spacing: 1.4px;
    text-transform: uppercase;
  }
  .show__title {
    font-size: clamp(22px, 2.4vw, 26px);
    font-weight: 700;
    letter-spacing: -0.025em;
    line-height: 1.15;
    margin-top: 14px;
  }
  .show__caption {
    font-size: 14.5px;
    color: var(--ink-dim);
    line-height: 1.55;
    margin-top: 14px;
  }
  .show__phone {
    margin-top: 36px;
    transform: scale(0.86) translateY(20px);
    transform-origin: center top;
    margin-bottom: -90px;
  }

  @media (min-width: 960px) {
    .show__rail {
      grid-template-columns: repeat(3, 1fr);
      gap: 0;
      border: 1px solid var(--rule);
      border-radius: var(--r-card);
      overflow: hidden;
    }
    .show__card {
      border: none;
      border-right: 1px solid var(--rule);
      border-radius: 0;
      padding: 48px 28px 0;
    }
    .show__card:nth-child(3n) { border-right: none; }
    .show__card:nth-child(2) { background: #EEF2EE; }
    .show__card:nth-child(3) { background: #F0EDE8; }
  }

  /* Mobile: horizontal-scroll snap carousel */
  @media (max-width: 759px) {
    .show__rail {
      grid-auto-flow: column;
      grid-auto-columns: 80%;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      gap: 16px;
      padding-bottom: 8px;
      margin-inline: calc(-1 * var(--container-px));
      padding-inline: var(--container-px);
    }
    .show__card { scroll-snap-align: start; }
  }
</style>
