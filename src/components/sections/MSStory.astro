---
import { STORY } from '../../data/copy';

const [left, right] = STORY.case.studios;
---

<section class="section" id="story" aria-labelledby="caseHeading">
  <div class="container">
    <div class="section-head" style="margin-bottom:48px">
      <span class="eyebrow">{STORY.eyebrow}</span>
      <h2 id="caseHeading">{STORY.head}</h2>
    </div>

    <div class="case">
      <div class="case__photos">
        <div
          class="case__photo"
          role="img"
          aria-label={left.photo.alt}
          style={`background-image:url('${left.photo.src}'); background-position:${left.photo.position}`}
        >
          <span class="case__pill">{left.name}</span>
        </div>
        <div
          class="case__photo"
          role="img"
          aria-label={right.photo.alt}
          style={`background-image:url('${right.photo.src}'); background-position:${right.photo.position}`}
        >
          <span class="case__pill">{right.name}</span>
        </div>
      </div>

      <div class="case__body">
        <div class="case__titlecard">
          <h3>{STORY.case.titleLeft} <span class="case__x">×</span> {STORY.case.titleRight}</h3>
          <span class="case__loc">
            <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            {STORY.case.location}
          </span>
        </div>

        <div class="case__metrics">
          <div class="case__row case__row--head">
            <div class="case__cell"><div class="case__name">{left.name}</div><div class="case__mod">{left.mod}</div></div>
            <div class="case__cell"><div class="case__name">{right.name}</div><div class="case__mod">{right.mod}</div></div>
          </div>

          <div class="case__row case__row--body">
            <div class="case__cell"><p class="case__quote">{left.quote}</p></div>
            <div class="case__cell"><p class="case__quote">{right.quote}</p></div>
          </div>

          <div class="case__cross">
            <span class="case__cross-n case__cross-n--l">{left.crossovers}</span>
            <span class="case__cross-n case__cross-n--r">{right.crossovers}</span>
            <span class="case__cross-cap">crossovers sent each month</span>
          </div>

          <div class="case__row case__row--stats">
            <div class="case__cell"><div class="case__stat"><span class="n">{left.upgradedPct}</span><span class="l">of members upgraded</span></div></div>
            <div class="case__cell"><div class="case__stat"><span class="n">{right.upgradedPct}</span><span class="l">of members upgraded</span></div></div>
          </div>

          <ul class="case__credits">
            {STORY.case.credits.map((c) => <li>{c}</li>)}
          </ul>
        </div>
      </div>
    </div>

    <h3 class="voices-head">{STORY.voicesHead}</h3>
    <div class="voices">
      {STORY.voices.map((v) => (
        <figure class="voice">
          <div class="voice__mark" aria-hidden="true">"</div>
          <blockquote><p>{v.q}</p></blockquote>
          <figcaption class="voice__who">
            <div class="voice__av">{v.initials}</div>
            <div>
              <div class="voice__name">{v.name}</div>
              <div class="voice__role">{v.role}</div>
            </div>
          </figcaption>
        </figure>
      ))}
    </div>
  </div>
</section>

<style>
  .case {
    display: grid;
    grid-template-columns: 1fr;
    gap: 32px;
    background: #fff;
    border: 1px solid var(--rule);
    border-radius: var(--r-sheet);
    overflow: hidden;
    box-shadow: var(--shadow-sm);
  }
  .case__photos {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2px;
    background: var(--rule);
  }
  .case__photo {
    position: relative;
    aspect-ratio: 4 / 3;
    background-size: cover;
    background-position: center;
  }
  .case__pill {
    position: absolute;
    bottom: 14px;
    left: 14px;
    background: rgba(15, 15, 18, 0.7);
    color: #fff;
    padding: 6px 12px;
    border-radius: var(--r-pill);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.02em;
    backdrop-filter: blur(8px);
  }

  .case__body { padding: 32px clamp(20px, 4vw, 40px) 40px; }
  .case__titlecard {
    display: flex;
    flex-direction: column;
    gap: 8px;
    align-items: flex-start;
    margin-bottom: 24px;
  }
  .case__titlecard h3 {
    font-size: clamp(22px, 2.4vw, 28px);
    font-weight: 800;
    letter-spacing: -0.02em;
    color: var(--navy);
  }
  .case__x { color: var(--navy-400); margin: 0 6px; font-weight: 500; }
  .case__loc {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: var(--ink-dim);
    font-size: 14px;
    font-weight: 600;
  }
  .case__loc svg { color: var(--pink); }

  .case__metrics { display: grid; gap: 24px; }
  .case__row {
    display: grid;
    grid-template-columns: 1fr;
    gap: 20px;
  }
  .case__cell { min-width: 0; }
  .case__name {
    font-size: 14px;
    font-weight: 700;
    color: var(--navy);
    letter-spacing: 0.02em;
  }
  .case__mod {
    font-size: 12px;
    color: var(--ink-mute);
    margin-top: 2px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }
  .case__quote {
    font-size: 15px;
    line-height: 1.55;
    color: var(--ink);
    font-style: italic;
    opacity: 0.92;
  }

  .case__cross {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 8px;
    align-items: end;
    padding: 20px;
    background: var(--cream);
    border-radius: var(--r-card);
    position: relative;
  }
  .case__cross-n {
    font-size: clamp(36px, 4vw, 56px);
    font-weight: 800;
    letter-spacing: -0.03em;
    color: var(--navy);
    line-height: 1;
  }
  .case__cross-n--r { text-align: right; color: var(--pink); }
  .case__cross-cap {
    grid-column: 1 / -1;
    text-align: center;
    font-size: 12px;
    color: var(--ink-mute);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-top: 6px;
  }

  .case__stat { display: flex; align-items: baseline; gap: 10px; }
  .case__stat .n {
    font-size: clamp(24px, 2.4vw, 32px);
    font-weight: 800;
    color: var(--navy);
    letter-spacing: -0.02em;
  }
  .case__stat .l { font-size: 13px; color: var(--ink-dim); }

  .case__credits {
    display: grid;
    gap: 8px;
    padding-top: 20px;
    border-top: 1px solid var(--rule);
    margin: 0;
    list-style: none;
  }
  .case__credits li {
    font-size: 12.5px;
    color: var(--ink-dim);
    line-height: 1.5;
    padding-left: 14px;
    position: relative;
  }
  .case__credits li::before {
    content: '';
    position: absolute;
    left: 0; top: 8px;
    width: 4px; height: 4px;
    border-radius: 50%;
    background: var(--pink);
  }

  .voices-head {
    margin-top: 80px;
    font-size: clamp(22px, 2.4vw, 28px);
    font-weight: 700;
    color: var(--navy);
    letter-spacing: -0.02em;
  }
  .voices {
    margin-top: 32px;
    display: grid;
    grid-template-columns: 1fr;
    gap: 20px;
  }
  .voice {
    background: #fff;
    border: 1px solid var(--rule);
    border-radius: var(--r-card);
    padding: 28px;
    box-shadow: var(--shadow-xs);
    position: relative;
  }
  .voice__mark {
    font-size: 56px;
    font-weight: 800;
    line-height: 0.6;
    color: var(--pink);
    margin-bottom: 4px;
  }
  .voice blockquote { font-size: 15px; line-height: 1.6; color: var(--ink); }
  .voice__who { display: flex; align-items: center; gap: 12px; margin-top: 18px; }
  .voice__av {
    width: 40px; height: 40px;
    border-radius: 50%;
    background: var(--navy);
    color: #fff;
    display: grid; place-items: center;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.04em;
  }
  .voice__name { font-size: 14px; font-weight: 700; color: var(--navy); }
  .voice__role { font-size: 12px; color: var(--ink-mute); }

  @media (min-width: 760px) {
    .case { grid-template-columns: 1fr 1.1fr; }
    .case__photos { grid-template-columns: 1fr; gap: 2px; }
    .case__row { grid-template-columns: 1fr 1fr; }
    .voices { grid-template-columns: repeat(3, 1fr); }
  }
</style>
