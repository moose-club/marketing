---
import { MEMBERS } from '../../data/copy';
---

<section class="section section--cream" id="members" aria-labelledby="memberHeading">
  <div class="container">
    <div class="members__grid">
      <div class="members__copy">
        <span class="eyebrow" data-reveal>{MEMBERS.eyebrow}</span>
        <h2 id="memberHeading" class="members__head" data-reveal style="--ri:1" set:html={MEMBERS.headHtml}></h2>
        <p class="lede members__lede" data-reveal style="--ri:2">
          {MEMBERS.ledeLines.map((line) => <span class="members__lede-line">{line}</span>)}
        </p>

        <div class="members__commercials">
          {MEMBERS.commercials.map((c, i) => (
            <div class="mc" data-reveal="pop" style={`--ri:${3 + i}`}>
              <div class="mc__k">{c.k}</div>
              <div class="mc__v"><span class="tnum" data-countup>{c.v}</span><span class="mc__u">{c.u}</span></div>
              <div class="mc__d">{c.d}</div>
            </div>
          ))}
        </div>

        <p class="members__note" data-reveal style="--ri:5" set:html={MEMBERS.noteHtml}></p>
      </div>

      <div class="members__phone-stage" data-reveal="right" style="--ri:2">
        <div class="phone">
          <div class="phone__screen">
            <img
              class="phone__shot"
              src="/photos/member-app-schedule.webp"
              width="920"
              height="2000"
              alt="The Moose member app showing a day's class schedule at nearby partner studios — each class bookable with credits."
              loading="lazy"
              decoding="async"
            />
          </div>
        </div>

        <div class="members__callout" data-reveal style="--ri:4">
          <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg>
          <p>
            {MEMBERS.calloutLines.map((line) => <span class="members__callout-line">{line}</span>)}
          </p>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .members__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 56px;
    /* Align column tops so the phone starts level with the heading block,
       rather than floating above it. */
    align-items: start;
  }
  .members__head {
    font-size: clamp(24px, 3.4vw, 46px);
    font-weight: 800;
    letter-spacing: -0.025em;
    line-height: 1.08;
    color: var(--navy);
    margin-bottom: 8px;
  }
  .members__head em { color: var(--pink); font-style: normal; }
  .members__lede { margin-top: 18px; font-weight: 400; }
  .members__lede-line { display: block; }
  .members__lede-line + .members__lede-line { margin-top: 0.8em; }

  .members__commercials {
    display: grid;
    grid-template-columns: 1fr;
    gap: 14px;
    margin-top: 28px;
  }
  .mc {
    background: #fff;
    border: 1px solid var(--rule);
    border-radius: var(--r-card);
    padding: 22px;
    box-shadow: var(--shadow-xs);
  }
  .mc__k {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--pink);
  }
  .mc__v {
    font-size: clamp(28px, 3vw, 36px);
    font-weight: 800;
    color: var(--navy);
    margin-top: 8px;
    letter-spacing: -0.02em;
    line-height: 1;
    display: flex;
    align-items: baseline;
    gap: 6px;
  }
  .mc__u {
    font-size: 13px;
    color: var(--ink-mute);
    font-weight: 600;
    letter-spacing: 0;
  }
  .mc__d {
    font-size: 13px;
    color: var(--ink-dim);
    margin-top: 8px;
    line-height: 1.4;
  }

  .members__note {
    margin-top: 24px;
    font-size: 14px;
    color: var(--ink-dim);
  }
  .members__note a {
    color: var(--pink);
    font-weight: 600;
    text-decoration: underline;
    text-decoration-color: transparent;
    transition: text-decoration-color var(--dur-fast) var(--ease-out);
  }
  .members__note a:hover { text-decoration-color: var(--pink); }

  /* ───── Phone mock — navy frame around a real app screenshot ───── */
  .members__phone-stage {
    display: grid;
    gap: 24px;
    justify-items: center;
  }
  .phone {
    width: 320px;
    background: var(--navy);
    border-radius: 44px;
    padding: 12px;
    box-shadow: var(--shadow-lg);
    position: relative;
    animation: phone-float 6.5s ease-in-out infinite alternate;
  }
  @keyframes phone-float {
    from { transform: translateY(0); }
    to   { transform: translateY(-10px); }
  }
  .phone__screen {
    background: var(--paper);
    border-radius: 34px;
    overflow: hidden;
    /* Match the screenshot's aspect ratio so it fills the screen with no crop. */
    aspect-ratio: 920 / 2000;
  }
  .phone__shot {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .members__callout {
    display: flex;
    gap: 12px;
    align-items: flex-start;
    max-width: 320px;
    padding: 16px;
    background: rgba(26, 43, 95, 0.04);
    border: 1px solid var(--rule);
    border-radius: var(--r-card);
    color: var(--ink-dim);
    font-size: 12.5px;
    line-height: 1.5;
  }
  .members__callout svg { color: var(--pink); flex-shrink: 0; margin-top: 1px; }
  .members__callout-line { display: block; }
  .members__callout-line + .members__callout-line { margin-top: 0.6em; }

  @media (min-width: 760px) {
    .members__commercials { grid-template-columns: 1fr 1fr; }
  }
  @media (min-width: 960px) {
    .members__grid { grid-template-columns: 1fr 1fr; gap: 80px; }
  }
</style>
