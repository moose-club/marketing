---
import { MEMBERS } from '../../data/copy';
---

<section class="section section--cream" id="members" aria-labelledby="memberHeading">
  <div class="container">
    <div class="members__grid">
      <div class="members__copy">
        <span class="eyebrow" data-reveal>{MEMBERS.eyebrow}</span>
        <h2 id="memberHeading" class="members__head" data-reveal style="--ri:1" set:html={MEMBERS.headHtml}></h2>
        <p class="lede members__lede" data-reveal style="--ri:2">
          {MEMBERS.ledeLines.map((line) => <span class="members__lede-line">{line}</span>)}
        </p>

        <div class="members__commercials">
          {MEMBERS.commercials.map((c, i) => (
            <div class="mc" data-reveal="pop" style={`--ri:${3 + i}`}>
              <div class="mc__k">{c.k}</div>
              <div class="mc__v"><span class="tnum" data-countup>{c.v}</span><span class="mc__u">{c.u}</span></div>
              <div class="mc__d">{c.d}</div>
            </div>
          ))}
        </div>

        <p class="members__note" data-reveal style="--ri:5" set:html={MEMBERS.noteHtml}></p>
      </div>

      <div class="members__phone-stage" data-reveal="right" style="--ri:2">
        <div class="phone" role="img" aria-label="Moose member app showing monthly crossover credits and nearby partner studios">
          <div class="phone__notch" aria-hidden="true"></div>
          <div class="phone__screen">
            <div class="phone__status"><span>9:41</span><span>Moose</span></div>
            <div class="phone__body">
              <div class="phone__greet">
                <div>
                  <div class="phone__hi">{MEMBERS.phone.greetHi}</div>
                  <div class="phone__nm">{MEMBERS.phone.greetName}</div>
                </div>
                <div class="phone__av">{MEMBERS.phone.greetName[0]}</div>
              </div>

              <div class="phone__anchor">
                <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 12 12 3l9 9"/><path d="M5 10v10h14V10"/></svg>
                Member at <b>&nbsp;{MEMBERS.phone.anchorStudio}</b>
              </div>

              <div class="phone__credits">
                <div class="phone__credits-top">
                  <span class="phone__credits-lab">{MEMBERS.phone.creditsLabel}</span>
                  <span class="phone__credits-val">{MEMBERS.phone.creditsMonth}</span>
                </div>
                <div class="phone__credits-num">{MEMBERS.phone.creditsLeft.split(' ')[0]} <em>{MEMBERS.phone.creditsLeft.split(' ').slice(1).join(' ')}</em></div>
                <div class="phone__credits-track"><i></i></div>
              </div>

              <div class="phone__sec">{MEMBERS.phone.sectionTitle}</div>
              <div class="phone__filters">
                {MEMBERS.phone.filters.map((f, i) => (
                  <span class:list={['phone__chip', i === 0 && 'phone__chip--on']}>{f}</span>
                ))}
              </div>

              <div class="phone__sched">
                {MEMBERS.phone.slots.map((s) => (
                  <div class="phone__slot">
                    <span class="phone__time">{s.time}<small>{s.meridiem}</small></span>
                    <div class="phone__slot-i">
                      <div class="phone__nm-sm">{s.name}</div>
                      <div class="phone__mt">{s.meta}</div>
                    </div>
                    <span class="phone__book">Book</span>
                  </div>
                ))}
              </div>
            </div>
          </div>
        </div>

        <div class="members__callout" data-reveal style="--ri:4">
          <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg>
          <p>
            {MEMBERS.calloutLines.map((line) => <span class="members__callout-line">{line}</span>)}
          </p>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .members__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 56px;
    align-items: center;
  }
  .members__head {
    font-size: var(--t-display-m);
    font-weight: 800;
    letter-spacing: -0.025em;
    line-height: 1.08;
    color: var(--navy);
    margin-bottom: 8px;
  }
  .members__head em { color: var(--pink); font-style: normal; }
  .members__lede { margin-top: 18px; }
  .members__lede-line { display: block; }
  .members__lede-line + .members__lede-line { margin-top: 0.8em; }

  .members__commercials {
    display: grid;
    grid-template-columns: 1fr;
    gap: 14px;
    margin-top: 28px;
  }
  .mc {
    background: #fff;
    border: 1px solid var(--rule);
    border-radius: var(--r-card);
    padding: 22px;
    box-shadow: var(--shadow-xs);
  }
  .mc__k {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--ink-mute);
  }
  .mc__v {
    font-size: clamp(28px, 3vw, 36px);
    font-weight: 800;
    color: var(--navy);
    margin-top: 8px;
    letter-spacing: -0.02em;
    line-height: 1;
    display: flex;
    align-items: baseline;
    gap: 6px;
  }
  .mc__u {
    font-size: 13px;
    color: var(--ink-mute);
    font-weight: 600;
    letter-spacing: 0;
  }
  .mc__d {
    font-size: 13px;
    color: var(--ink-dim);
    margin-top: 8px;
    line-height: 1.4;
  }

  .members__note {
    margin-top: 24px;
    font-size: 14px;
    color: var(--ink-dim);
  }
  .members__note a {
    color: var(--pink);
    font-weight: 600;
    text-decoration: underline;
    text-decoration-color: transparent;
    transition: text-decoration-color var(--dur-fast) var(--ease-out);
  }
  .members__note a:hover { text-decoration-color: var(--pink); }

  /* ───── Phone mock (pure CSS — not a real product UI) ───── */
  .members__phone-stage {
    display: grid;
    gap: 24px;
    justify-items: center;
  }
  .phone {
    width: 320px;
    height: 660px;
    background: var(--navy);
    border-radius: 44px;
    padding: 12px;
    box-shadow: var(--shadow-lg);
    position: relative;
    animation: phone-float 6.5s ease-in-out infinite alternate;
  }
  @keyframes phone-float {
    from { transform: translateY(0); }
    to   { transform: translateY(-10px); }
  }
  .phone__notch {
    position: absolute;
    top: 18px;
    left: 50%;
    transform: translateX(-50%);
    width: 100px;
    height: 28px;
    background: #000;
    border-radius: 14px;
  }
  .phone__screen {
    background: #fff;
    border-radius: 34px;
    height: 100%;
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }
  .phone__status {
    padding: 14px 26px 6px;
    display: flex;
    justify-content: space-between;
    font-size: 12px;
    font-weight: 700;
    color: var(--navy);
    letter-spacing: 0.02em;
  }
  .phone__body { padding: 20px 22px 22px; display: flex; flex-direction: column; gap: 14px; overflow: hidden; }

  .phone__greet { display: flex; justify-content: space-between; align-items: center; }
  .phone__hi { font-size: 12px; color: var(--ink-mute); }
  .phone__nm { font-size: 20px; font-weight: 700; color: var(--navy); letter-spacing: -0.01em; }
  .phone__av {
    width: 40px; height: 40px;
    border-radius: 50%;
    background: var(--pink);
    color: #fff;
    display: grid; place-items: center;
    font-weight: 700;
    font-size: 16px;
  }

  .phone__anchor {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 7px 12px;
    background: var(--cream);
    border-radius: var(--r-pill);
    font-size: 12px;
    color: var(--navy);
    font-weight: 500;
    align-self: flex-start;
  }

  .phone__credits {
    background: var(--navy);
    color: #fff;
    border-radius: var(--r-card);
    padding: 16px 18px;
  }
  .phone__credits-top {
    display: flex;
    justify-content: space-between;
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    opacity: 0.7;
  }
  .phone__credits-num {
    font-size: 28px;
    font-weight: 800;
    margin-top: 6px;
    letter-spacing: -0.02em;
  }
  .phone__credits-num em {
    font-size: 13px;
    font-style: normal;
    opacity: 0.7;
    font-weight: 500;
    margin-left: 6px;
    letter-spacing: 0;
  }
  .phone__credits-track {
    margin-top: 12px;
    height: 6px;
    border-radius: 3px;
    background: rgba(255, 255, 255, 0.18);
    overflow: hidden;
  }
  .phone__credits-track i {
    display: block;
    height: 100%;
    width: 75%;
    background: var(--pink);
    border-radius: 3px;
    transition: width 0.9s var(--ease-out) 0.55s;
  }
  /* Credits bar fills once the phone has revealed (3 of 4 → 75%). */
  :global(html.js) .members__phone-stage:not(:global(.is-revealed)) .phone__credits-track i { width: 0; }

  .phone__sec {
    font-size: 11px;
    font-weight: 700;
    color: var(--ink-mute);
    text-transform: uppercase;
    letter-spacing: 0.16em;
  }
  .phone__filters { display: flex; gap: 6px; flex-wrap: wrap; }
  .phone__chip {
    font-size: 11px;
    font-weight: 600;
    padding: 6px 12px;
    border-radius: var(--r-pill);
    background: var(--cream);
    color: var(--ink-dim);
  }
  .phone__chip--on { background: var(--navy); color: #fff; }

  .phone__sched { display: flex; flex-direction: column; gap: 8px; }
  .phone__slot {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 10px 12px;
    border: 1px solid var(--rule);
    border-radius: var(--r-md);
    transition: opacity 0.5s var(--ease-out), transform 0.5s var(--ease-out);
  }
  /* Booking slots cascade in after the phone lands. */
  :global(html.js) .members__phone-stage:not(:global(.is-revealed)) .phone__slot {
    opacity: 0;
    transform: translateY(10px);
  }
  .phone__slot:nth-child(1) { transition-delay: 0.55s; }
  .phone__slot:nth-child(2) { transition-delay: 0.68s; }
  .phone__slot:nth-child(3) { transition-delay: 0.81s; }
  .phone__time {
    font-size: 14px;
    font-weight: 700;
    color: var(--navy);
    letter-spacing: -0.01em;
    width: 52px;
    flex-shrink: 0;
  }
  .phone__time small {
    font-size: 9px;
    font-weight: 600;
    text-transform: uppercase;
    margin-left: 1px;
    color: var(--ink-mute);
  }
  .phone__slot-i { flex: 1; min-width: 0; }
  .phone__nm-sm {
    font-size: 12px;
    font-weight: 700;
    color: var(--navy);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .phone__mt { font-size: 10px; color: var(--ink-mute); }
  .phone__book {
    font-size: 11px;
    font-weight: 700;
    color: var(--pink);
    padding: 6px 10px;
    border-radius: var(--r-pill);
    background: var(--pink-50);
  }

  .members__callout {
    display: flex;
    gap: 12px;
    align-items: flex-start;
    max-width: 320px;
    padding: 16px;
    background: rgba(26, 43, 95, 0.04);
    border: 1px solid var(--rule);
    border-radius: var(--r-card);
    color: var(--ink-dim);
    font-size: 12.5px;
    line-height: 1.5;
  }
  .members__callout svg { color: var(--pink); flex-shrink: 0; margin-top: 1px; }
  .members__callout-line { display: block; }
  .members__callout-line + .members__callout-line { margin-top: 0.6em; }

  @media (min-width: 760px) {
    .members__commercials { grid-template-columns: 1fr 1fr; }
  }
  @media (min-width: 960px) {
    .members__grid { grid-template-columns: 1fr 1fr; gap: 80px; }
  }
</style>
