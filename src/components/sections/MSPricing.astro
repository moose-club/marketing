---
import Eyebrow from '../primitives/Eyebrow.astro';
import { PRICING } from '../../data/copy';
---

<section class="pricing" id="pricing">
  <div class="container">
    <Eyebrow tone="pink">Pricing</Eyebrow>

    <div class="pricing__top">
      <h2 class="display-l pricing__head">
        You set the price.<br />
        <span class="pink">We just route the booking.</span>
      </h2>

      <div class="pricing__rate">
        <div class="pricing__rate-kicker">Today's rate</div>
        <div class="pricing__rate-n tnum">
          {PRICING.rate}<span class="pricing__rate-unit"> {PRICING.rateUnit}</span>
        </div>
        <p class="pricing__rate-note">{PRICING.rateNote}</p>
      </div>
    </div>

    <div class="pricing__pillars">
      {PRICING.pillars.map((b) => (
        <div>
          <div class="pricing__pillar-t">{b.t}</div>
          <p class="pricing__pillar-d">{b.d}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .pricing {
    background: var(--navy);
    color: var(--navy-on);
    padding-block: clamp(72px, 12vw, 120px);
  }
  .pricing :global(.eyebrow) { margin-bottom: 32px; }

  .pricing__top {
    display: grid;
    gap: 40px;
    align-items: end;
  }
  .pricing__head { color: var(--navy-on); }

  .pricing__rate {
    background: var(--navy-deep);
    border-radius: var(--r-card);
    padding: 32px 28px;
    border: 1px solid var(--navy-rule);
  }
  .pricing__rate-kicker {
    font-size: 12px;
    font-weight: 600;
    color: var(--pink);
    letter-spacing: 1.4px;
    text-transform: uppercase;
  }
  .pricing__rate-n {
    font-size: clamp(48px, 6vw, 64px);
    font-weight: 700;
    letter-spacing: -0.04em;
    color: var(--navy-on);
    margin-top: 12px;
    line-height: 1;
  }
  .pricing__rate-unit { font-size: 22px; color: var(--navy-dim); font-weight: 500; }
  .pricing__rate-note {
    font-size: 13.5px;
    color: var(--navy-dim);
    margin-top: 14px;
    line-height: 1.5;
  }

  .pricing__pillars {
    margin-top: clamp(48px, 8vw, 80px);
    display: grid;
    grid-template-columns: 1fr;
    gap: 32px;
    border-top: 1px solid var(--navy-rule);
    padding-top: 36px;
  }
  .pricing__pillar-t {
    font-size: 18px;
    font-weight: 700;
    color: var(--navy-on);
    letter-spacing: -0.3px;
  }
  .pricing__pillar-d {
    font-size: 14px;
    color: var(--navy-dim);
    margin-top: 10px;
    line-height: 1.55;
    max-width: 320px;
  }

  @media (min-width: 760px) {
    .pricing__pillars { grid-template-columns: repeat(3, 1fr); }
  }
  @media (min-width: 960px) {
    .pricing__top {
      grid-template-columns: 1.3fr 1fr;
      gap: 64px;
    }
  }
</style>
