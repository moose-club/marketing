---
import Eyebrow from '../primitives/Eyebrow.astro';
import { STEPS } from '../../data/copy';
---

<section class="how" id="how">
  <div class="container">
    <div class="how__head">
      <div>
        <Eyebrow>How it works</Eyebrow>
        <h2 class="display-l how__title">Four steps. Nine business days.</h2>
      </div>
      <p class="how__lede body-l">
        We do the integration, the scheduling sync, and the partner
        communications. You stay focused on your space, your trainers,
        and your members.
      </p>
    </div>

    <ol class="how__grid">
      {STEPS.map((s) => (
        <li class="how__step">
          <div class="how__n tnum">{s.n}</div>
          <div class="how__t">{s.t}</div>
          <p class="how__d">{s.d}</p>
        </li>
      ))}
    </ol>
  </div>
</section>

<style>
  .how { padding-block: clamp(80px, 12vw, 120px); }
  .how__head {
    display: grid;
    gap: 32px;
    margin-bottom: 56px;
  }
  .how__title { margin-top: 28px; }
  .how__lede { max-width: 460px; }

  .how__grid {
    display: grid;
    grid-template-columns: 1fr;
    border-top: 1px solid var(--rule);
  }
  .how__step {
    padding: 28px 0 32px;
    border-bottom: 1px solid var(--rule);
    min-height: 220px;
  }
  .how__step:last-child { border-bottom: none; }

  .how__n {
    font-size: 13px;
    font-weight: 600;
    color: var(--pink);
    letter-spacing: -0.2px;
  }
  .how__t {
    font-size: clamp(24px, 3vw, 28px);
    font-weight: 700;
    letter-spacing: -0.04em;
    margin-top: 32px;
    line-height: 1.05;
  }
  .how__d {
    font-size: 14px;
    color: var(--ink-dim);
    line-height: 1.55;
    margin-top: 12px;
    max-width: 240px;
  }

  @media (min-width: 640px) {
    .how__grid { grid-template-columns: 1fr 1fr; }
    .how__step {
      padding: 36px 28px 32px;
      border-right: 1px solid var(--rule);
    }
    .how__step:nth-child(2n) { border-right: none; }
    .how__step:first-child { padding-left: 0; }
    .how__step:nth-child(2) { padding-right: 0; }
  }
  @media (min-width: 960px) {
    .how__head { grid-template-columns: 1fr 1.4fr; gap: 64px; align-items: end; }
    .how__grid { grid-template-columns: repeat(4, 1fr); }
    .how__step {
      padding: 36px 28px 0;
      border-bottom: none;
      border-right: 1px solid var(--rule);
    }
    .how__step:nth-child(2n) { border-right: 1px solid var(--rule); }
    .how__step:last-child { border-right: none; }
    .how__step:first-child { padding-left: 0; }
    .how__step:nth-child(4) { padding-right: 0; }
  }
</style>
