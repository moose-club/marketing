---
import { NAV } from '../../data/copy';
---

<header class="nav" data-scrolled="false" id="siteHeader">
  <div class="nav__inner container">
    <a href="#top" class="nav__brand" aria-label="Moose home">
      <img
        src="/brand/logo/moose-wordmark-twotone.svg"
        alt="Moose"
        class="nav__logo"
      />
    </a>

    <nav class="nav__links" aria-label="Primary">
      {NAV.links.map((l) => <a href={l.href} class="nav__link">{l.label}</a>)}
    </nav>

    <a class="nav__cta" href={NAV.cta.href}>
      <span>{NAV.cta.label}</span>
      <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
    </a>

    <button
      class="nav__toggle"
      id="navToggle"
      aria-label="Open menu"
      aria-expanded="false"
      aria-controls="navMobile"
    >
      <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
    </button>
  </div>

  <nav class="nav__mobile" id="navMobile" aria-label="Mobile" data-open="false">
    {NAV.links.map((l) => <a href={l.href} class="nav__mobile-link">{l.label}</a>)}
    <a href={NAV.cta.href} class="nav__mobile-link nav__mobile-link--cta">{NAV.cta.label}</a>
  </nav>
</header>

<script>
  // Switch `data-scrolled` once past 16px so the header gains its blurred
  // background. Saves us from a permanent translucent bar over the hero.
  const nav = document.querySelector<HTMLElement>('.nav');
  if (nav) {
    const handler = () => nav.setAttribute('data-scrolled', String(window.scrollY > 16));
    handler();
    window.addEventListener('scroll', handler, { passive: true });
  }

  // Mobile menu toggle + auto-close on link tap.
  const toggle = document.getElementById('navToggle');
  const mobile = document.getElementById('navMobile');
  if (toggle && mobile) {
    toggle.addEventListener('click', () => {
      const open = toggle.getAttribute('aria-expanded') === 'true';
      toggle.setAttribute('aria-expanded', String(!open));
      mobile.dataset.open = String(!open);
    });
    mobile.addEventListener('click', (e) => {
      if ((e.target as HTMLElement).closest('a')) {
        toggle.setAttribute('aria-expanded', 'false');
        mobile.dataset.open = 'false';
      }
    });
  }
</script>

<style>
  .nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    transition: background var(--dur-base) var(--ease-out), border-color var(--dur-base), backdrop-filter var(--dur-base);
    border-bottom: 1px solid transparent;
  }
  .nav[data-scrolled='true'] {
    background: rgba(255, 255, 255, 0.86);
    backdrop-filter: blur(14px) saturate(140%);
    -webkit-backdrop-filter: blur(14px) saturate(140%);
    border-bottom-color: var(--rule);
    box-shadow: var(--shadow-xs);
  }
  .nav__inner {
    display: flex;
    align-items: center;
    gap: 24px;
    height: 72px;
  }
  .nav__brand { display: inline-flex; flex-shrink: 0; }
  .nav__logo {
    display: block;
    height: 30px;
    width: auto;
  }

  .nav__links {
    display: none;
    align-items: center;
    gap: 6px;
    margin-left: auto;
  }
  .nav__link {
    font-size: 14px;
    font-weight: 500;
    color: var(--ink-dim);
    padding: 9px 14px;
    border-radius: var(--r-sm);
    transition: color var(--dur-fast) var(--ease-out), background var(--dur-fast);
    white-space: nowrap;
  }
  .nav__link:hover { color: var(--ink); background: var(--navy-50); }

  .nav__cta {
    display: none;
    align-items: center;
    gap: 8px;
    background: var(--navy);
    color: #fff;
    padding: 11px 20px;
    border-radius: var(--r-pill);
    font-size: 14px;
    font-weight: 600;
    box-shadow: var(--shadow-xs);
    transition: background var(--dur-fast) var(--ease-out), transform var(--dur-fast);
    white-space: nowrap;
    margin-left: 8px;
  }
  .nav__cta svg { transition: transform var(--dur-fast) var(--ease-out); }
  .nav__cta:hover { background: var(--navy-lift); transform: translateY(-1px); }
  .nav__cta:hover svg { transform: translateX(3px); }

  .nav__toggle {
    margin-left: auto;
    width: 44px;
    height: 44px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--ink);
    border-radius: var(--r-sm);
  }

  .nav__mobile {
    display: none;
    flex-direction: column;
    padding: 8px var(--container-px) 20px;
    background: #fff;
    border-top: 1px solid var(--rule);
  }
  .nav__mobile[data-open='true'] { display: flex; }
  .nav__mobile-link {
    padding: 14px 4px;
    font-size: 16px;
    font-weight: 600;
    color: var(--ink);
    border-bottom: 1px solid var(--rule);
  }
  .nav__mobile-link:last-child { border-bottom: none; }
  .nav__mobile-link--cta {
    margin-top: 8px;
    background: var(--navy);
    color: #fff;
    text-align: center;
    border-radius: var(--r-pill);
    border-bottom: none;
    padding: 14px 18px;
  }

  @media (min-width: 760px) {
    .nav__toggle  { display: none; }
    .nav__mobile  { display: none !important; }
    .nav__links   { display: inline-flex; }
    .nav__cta     { display: inline-flex; }
  }
</style>
