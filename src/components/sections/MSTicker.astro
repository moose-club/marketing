---
import { MODALITIES } from '../../data/copy';

// Render the list twice for the seamless infinite scroll.
const items = [...MODALITIES, ...MODALITIES];
---

<section class="ticker" aria-label="Modalities on the network">
  <div class="ticker__viewport">
    <div class="ticker__track">
      {items.map((label) => {
        const isLast = label === '& more';
        return (
          <>
            <span class:list={['ticker__item', isLast && 'ticker__item--accent']}>{label}</span>
            <span class="ticker__sep" aria-hidden="true">◆</span>
          </>
        );
      })}
    </div>
  </div>
</section>

<style>
  .ticker {
    background: var(--navy-900);
    overflow: hidden;
    padding-block: 26px;
  }
  .ticker__viewport {
    width: 100%;
    overflow: hidden;
    mask-image: linear-gradient(90deg, transparent 0, #000 6%, #000 94%, transparent 100%);
    -webkit-mask-image: linear-gradient(90deg, transparent 0, #000 6%, #000 94%, transparent 100%);
  }
  .ticker__track {
    display: inline-flex;
    align-items: center;
    width: max-content;
    animation: ticker-scroll 38s linear infinite;
  }
  .ticker__item {
    display: inline-flex;
    align-items: center;
    font-size: 17px;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.66);
    letter-spacing: 0.01em;
    text-transform: capitalize;
    white-space: nowrap;
  }
  .ticker__item--accent {
    color: var(--pink);
    text-transform: none;
  }
  .ticker__sep {
    margin: 0 22px;
    color: var(--pink);
    font-size: 10px;
  }

  @keyframes ticker-scroll {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }
  @media (prefers-reduced-motion: reduce) {
    .ticker__track { animation: none; }
  }
</style>
