---
import { FOOTER } from '../../data/copy';

const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="container">
    <div class="footer__top">
      <div class="footer__brand">
        <img
          src="/brand/logo/moose-wordmark-white.svg"
          alt="Moose"
          class="footer__logo"
        />
        <p class="footer__tag">{FOOTER.tagline}</p>
        <a
          href={FOOTER.instagram.href}
          class="footer__ig"
          target="_blank"
          rel="noopener"
          aria-label={FOOTER.instagram.label}
        >
          <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect x="2" y="2" width="20" height="20" rx="5.5"></rect>
            <circle cx="12" cy="12" r="4"></circle>
            <circle cx="17.6" cy="6.4" r="1.1" fill="currentColor" stroke="none"></circle>
          </svg>
        </a>
      </div>

      <div class="footer__cols">
        {FOOTER.cols.map((c) => (
          <div class="footer__col">
            <h5>{c.title}</h5>
            {c.items.map((it) => {
              const isExternal = 'external' in it && it.external;
              return (
                <a
                  href={it.h}
                  class="footer__link"
                  {...(isExternal ? { target: '_blank', rel: 'noopener' } : {})}
                >
                  {it.l}
                </a>
              );
            })}
          </div>
        ))}
      </div>
    </div>

    <div class="footer__bot">
      <div class="footer__legal">
        <span>© {year} Moose Club. Made in Australia.</span>
        {FOOTER.legal.map((l) => <a href={l.h}>{l.l}</a>)}
      </div>
      <div class="footer__links">
        <a href="#register">Get involved or hear more</a>
        <a href="#top">Back to top</a>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--navy-900);
    color: #fff;
    padding-block: 64px 32px;
  }
  .footer__top {
    display: grid;
    grid-template-columns: 1fr;
    gap: 48px;
  }
  .footer__brand { display: grid; gap: 14px; }
  .footer__logo {
    display: block;
    height: 36px;
    width: auto;
  }
  .footer__tag {
    font-size: 14px;
    color: rgba(255, 255, 255, 0.55);
    line-height: 1.55;
    max-width: 320px;
  }
  .footer__ig {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: 999px;
    color: #fff;
    background: rgba(255, 255, 255, 0.08);
    transition: background var(--dur-fast) var(--ease-out), color var(--dur-fast);
  }
  .footer__ig:hover { background: var(--pink); color: #fff; }

  .footer__cols {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 32px 24px;
  }
  .footer__col { display: grid; gap: 10px; align-content: start; }
  .footer__col h5 {
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #fff;
    margin: 0 0 6px;
  }
  .footer__link {
    font-size: 13.5px;
    color: rgba(255, 255, 255, 0.6);
    transition: color var(--dur-fast) var(--ease-out);
  }
  .footer__link:hover { color: #fff; }

  .footer__bot {
    margin-top: 56px;
    padding-top: 24px;
    border-top: 1px solid rgba(255, 255, 255, 0.12);
    display: flex;
    justify-content: space-between;
    gap: 16px;
    flex-wrap: wrap;
    font-size: 12px;
    color: rgba(255, 255, 255, 0.45);
  }
  .footer__legal {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 16px;
  }
  .footer__legal a {
    color: rgba(255, 255, 255, 0.6);
    transition: color var(--dur-fast) var(--ease-out);
  }
  .footer__legal a:hover { color: #fff; }
  .footer__links { display: flex; gap: 20px; }
  .footer__links a { color: rgba(255, 255, 255, 0.6); }
  .footer__links a:hover { color: #fff; }

  @media (min-width: 760px) {
    .footer__cols { grid-template-columns: repeat(3, 1fr); }
  }
  @media (min-width: 960px) {
    .footer__top { grid-template-columns: 1.2fr 3fr; gap: 64px; }
  }
</style>
