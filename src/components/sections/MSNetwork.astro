---
import Eyebrow from '../primitives/Eyebrow.astro';
import StudioTile from '../primitives/StudioTile.astro';
import { PARTNERS, resolvePartner } from '../../data/copy';

const tiles = PARTNERS.slice(0, 20).map(resolvePartner);
---

<section class="network" id="network">
  <div class="container">
    <div class="network__head">
      <div>
        <Eyebrow>The network</Eyebrow>
        <h2 class="display-l network__title">
          218 studios. <span class="ink-dim">Three cities. One pass.</span>
        </h2>
      </div>
      <div class="network__legend">
        <span class="network__live"><span class="network__dot"></span>218 live</span>
        <span>· 24 onboarding</span>
        <span>· 11 waitlisted</span>
      </div>
    </div>

    <div class="network__grid">
      {tiles.map((p) => <StudioTile partner={p} />)}
    </div>

    <div class="network__meta">
      <svg width="13" height="13" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <path d="M12 22s7-7.5 7-13a7 7 0 10-14 0c0 5.5 7 13 7 13z" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
        <circle cx="12" cy="9" r="2.5" stroke="currentColor" stroke-width="1.8"/>
      </svg>
      Studios across Sydney, Melbourne and Brisbane · Perth Q3 2026
    </div>
  </div>
</section>

<style>
  .network { padding-block: clamp(80px, 12vw, 120px); }

  .network__head {
    display: grid;
    gap: 24px;
    align-items: end;
    margin-bottom: 36px;
  }
  .network__title { margin-top: 28px; }
  .network__title .ink-dim { color: var(--ink-dim); }

  .network__legend {
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
    font-size: 13px;
    color: var(--ink-dim);
    font-weight: 500;
  }
  .network__live { display: inline-flex; align-items: center; gap: 6px; }
  .network__dot { width: 7px; height: 7px; border-radius: 4px; background: var(--success); }

  .network__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 14px;
  }

  .network__meta {
    margin-top: 28px;
    padding: 12px 18px;
    border-radius: var(--r-pill);
    border: 1px solid var(--rule);
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 13px;
    color: var(--ink-dim);
    font-weight: 500;
  }

  @media (min-width: 640px) { .network__grid { grid-template-columns: repeat(3, 1fr); } }
  @media (min-width: 960px) {
    .network__head { grid-template-columns: 1fr auto; }
    .network__grid { grid-template-columns: repeat(4, 1fr); }
  }
  @media (min-width: 1280px) {
    .network__grid { grid-template-columns: repeat(5, 1fr); }
  }
</style>
