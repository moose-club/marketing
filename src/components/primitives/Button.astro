---
// Three button variants. Per brand discipline (SPEC §14):
//   • Never put a pink CTA and a navy CTA on the same screen.
//   • pink-primary  — page primary action (the apply CTA)
//   • ghost-on-navy — secondary inside a navy section
//   • ghost-on-paper — secondary inside a light section

type Variant = 'pink-primary' | 'ghost-on-navy' | 'ghost-on-paper' | 'navy-primary';

interface Props {
  href?: string;
  variant?: Variant;
  size?: 'md' | 'lg';
  trailing?: string;       // appended after the label, kept on the same line
  class?: string;
  ariaLabel?: string;
  // Allow rendering as a <button type="submit"> etc., not just an anchor.
  type?: 'button' | 'submit';
}

const {
  href,
  variant = 'pink-primary',
  size = 'lg',
  trailing,
  class: className,
  ariaLabel,
  type = 'button',
} = Astro.props;

const Tag = href ? 'a' : 'button';
const extraProps: Record<string, unknown> = href
  ? { href }
  : { type };
if (ariaLabel) extraProps['aria-label'] = ariaLabel;
---

<Tag
  class:list={['btn', `btn--${variant}`, `btn--${size}`, className]}
  {...extraProps}
>
  <span class="btn__label"><slot /></span>
  {trailing && <span class="btn__trailing tnum">{trailing}</span>}
  <svg class="btn__arrow" width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true">
    <path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" />
  </svg>
</Tag>

<style>
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    border-radius: var(--r-tile);
    font-weight: 600;
    letter-spacing: -0.01em;
    cursor: pointer;
    transition: transform 120ms ease-out, background-color 120ms ease-out, color 120ms ease-out, border-color 120ms ease-out;
    text-decoration: none;
    min-height: 44px;
    white-space: nowrap;
  }
  .btn:active { transform: translateY(1px); }

  .btn--lg { font-size: 15px; padding: 14px 22px; }
  .btn--md { font-size: 13.5px; padding: 10px 18px; border-radius: var(--r-pill); }

  .btn--pink-primary {
    background: var(--pink);
    color: var(--pink-on);
  }
  .btn--pink-primary:hover { background: #d63f7c; }

  .btn--navy-primary {
    background: var(--navy);
    color: var(--navy-on);
  }
  .btn--navy-primary:hover { background: var(--navy-lift); }

  .btn--ghost-on-navy {
    background: transparent;
    color: var(--navy-on);
    border: 1px solid var(--navy-rule);
  }
  .btn--ghost-on-navy:hover {
    background: rgba(255, 255, 255, 0.06);
    border-color: rgba(255, 255, 255, 0.28);
  }

  .btn--ghost-on-paper {
    background: transparent;
    color: var(--ink);
    border: 1px solid var(--ink);
  }
  .btn--ghost-on-paper:hover { background: rgba(15, 15, 18, 0.06); }

  .btn__trailing { font-size: 0.9em; opacity: 0.85; }
  .btn__arrow { flex-shrink: 0; }

  @media (prefers-reduced-motion: reduce) {
    .btn { transition: none; }
    .btn:active { transform: none; }
  }
</style>
