---
import Base from '../layouts/Base.astro';

import MSNav      from '../components/sections/MSNav.astro';
import MSHero     from '../components/sections/MSHero.astro';
import MSTicker   from '../components/sections/MSTicker.astro';
import MSModel    from '../components/sections/MSModel.astro';
import MSNetwork  from '../components/sections/MSNetwork.astro';
import MSValue    from '../components/sections/MSValue.astro';
import MSStory    from '../components/sections/MSStory.astro';
import MSMembers  from '../components/sections/MSMembers.astro';
import MSRegister from '../components/sections/MSRegister.astro';
import MSFooter   from '../components/sections/MSFooter.astro';
---

<Base
  title="Moose — Reciprocal partnerships for boutique fitness studios"
  description="Moose lets boutique fitness studios in Australia form local, reciprocal partnerships with complementary operators and sell members a premium crossover upgrade. Members stay anchored to you. You gain a new recurring revenue stream and a stickier membership base."
  preloadImage="/photos/hero-strength.webp"
>
  <MSNav />
  <main id="main">
    <MSHero />
    <MSTicker />
    <MSModel />
    <MSNetwork />
    <MSValue />
    <MSStory />
    <MSMembers />
    <MSRegister />
  </main>
  <MSFooter />
</Base>
